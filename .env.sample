# UI (SSR-клиент). Для OAuth Яндекса — 9000 (whitelist Практикума: 3000, 5000, 9000; не 5173).
CLIENT_PORT=9000
SERVER_PORT=3000
POSTGRES_HOST=localhost
# Docker Postgres (образ postgres:16-alpine):
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
# Порт на **хосте** (в контейнере всегда 5432). По умолчанию 5433 — чтобы не конфликтовать с Homebrew Postgres на macOS.
# После смены порта: POSTGRES_PORT=5433 docker compose up -d postgres --force-recreate
POSTGRES_PORT=5433
# 8.10 demo MCR (sprint_8):
# POSTGRES_PORT=5432
# Если локальный PostgreSQL уже занимает 5432, поставьте любой свободный порт,
# например POSTGRES_PORT=5434, и запускайте миграции через yarn db:migrate.
#
# Ошибка «role postgres does not exist» при yarn db:migrate:
# 1) На :5432 отвечает не Docker, а локальный Postgres (brew) — у него нет роли postgres.
#    Проверка: lsof -i :5432
#    Решение A: POSTGRES_PORT=5433 + docker compose up -d postgres (см. docker-compose.yml).
#    Решение B: brew services stop postgresql (оставить только Docker на 5432 и POSTGRES_PORT=5432).
#    Решение C (миграции без смены порта): yarn db:migrate:docker
# 2) Либо явно POSTGRES_USER=<ваш macOS user> только если работаете с brew PG, не с Docker.
# POSTGRES_USE_OS_USER=1
#
# Браузер и SSR (если не переопределено в vite): наш Node API
VITE_APP_API_URL=http://localhost:3000
EXTERNAL_SERVER_URL=http://localhost:3000
# Только внутри docker-сети (контейнер client). На хосте yarn dev:client игнорируется → localhost:3000.
INTERNAL_SERVER_URL=http://server:3000
# Origin Практикума для SSR-прокси (без /api/v2)
PRAKTIKUM_API_URL=https://ya-praktikum.tech
# Должен совпадать с origin приложения (CLIENT_PORT), без завершающего /
VITE_YANDEX_OAUTH_REDIRECT_URI=http://localhost:9000
#
# Локальные e2e / отладка без запроса к API Практикума (только при NODE_ENV !== production):
# LOCAL_PRAKTIKUM_AUTH_BYPASS=1
# Опционально подставляемый «пользователь»:
# LOCAL_PRAKTIKUM_USER_ID=999001
# LOCAL_PRAKTIKUM_USER_DISPLAY=e2e-local
#
# Модераторы форума (id через запятую): могут PATCH/DELETE чужие темы и комментарии.
# FORUM_MODERATOR_PRAKTIKUM_IDS=12345,67890
#
# Темизация UI: гостевая cookie anonymous_session_id (72 ч) выставляется сервером при PUT /api/ui/theme

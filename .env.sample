CLIENT_PORT=5173
SERVER_PORT=3000
POSTGRES_HOST=localhost
# Для официального образа Docker Postgres — оставляем так:
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432
VITE_APP_API_URL=http://localhost:3000
EXTERNAL_SERVER_URL=http://localhost:3000
INTERNAL_SERVER_URL=http://server:3000
PRAKTIKUM_API_URL=https://ya-praktikum.tech
EXTERNAL_SERVER_URL=http://localhost:3001
INTERNAL_SERVER_URL=http://server:3001
#
# Браузер ходит на API через same-origin прокси SSR-клиента (packages/client/server/apiProxy.ts):
#   /api/v2/*  → Практикум, /api/forum/* и /friends, /user → packages/server.
# Открывайте приложение по URL клиента (yarn dev: CLIENT_PORT, Docker: http://localhost:5173).
# VITE_APP_API_URL — только для SSR/Node и прямых запросов без прокси; в браузере не используется.
VITE_APP_API_URL=http://localhost:3000
EXTERNAL_SERVER_URL=http://localhost:3000
INTERNAL_SERVER_URL=http://server:3000
#
# Локальные e2e / отладка без запроса к API Практикума (только при NODE_ENV !== production):
# LOCAL_PRAKTIKUM_AUTH_BYPASS=1
# Опционально подставляемый «пользователь»:
# LOCAL_PRAKTIKUM_USER_ID=999001
# LOCAL_PRAKTIKUM_USER_DISPLAY=e2e-local
#
# Модераторы форума (id через запятую): могут PATCH/DELETE чужие темы и комментарии.
# FORUM_MODERATOR_PRAKTIKUM_IDS=12345,67890
#
# Темизация UI: гостевая cookie anonymous_session_id (72 ч) выставляется сервером при PUT /api/ui/theme
PRAKTIKUM_API_URL=https://ya-praktikum.tech

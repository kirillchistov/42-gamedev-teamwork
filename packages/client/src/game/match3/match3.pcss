.match3 {
  width: 100%;
  max-width: 100%;
  margin-top: 8px;
}

.match3-page__toast-wrap {
  position: sticky;
  top: 8px;
  z-index: 20;
  margin-bottom: 12px;
  display: flex;
  justify-content: center;
}

.match3-page__toast {
  padding: 10px 14px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  color: #0f172a;
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid rgba(79, 70, 229, 0.25);
  box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
}

.match3-page__title {
  text-align: center;
}

.match3-page__note {
  text-align: center;
}

.match3-page__settings-btn {
  border: none;
  background: transparent;
  color: var(--color-accent-primary);
  text-decoration: underline;
  cursor: pointer;
  padding: 0;
  font: inherit;
}

.match3-page__settings-grid {
  margin: 12px auto 16px;
  max-width: 560px;
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(
    auto-fit,
    minmax(160px, 1fr)
  );
}

.match3-page__settings-label {
  display: grid;
  gap: 4px;
}

.match3__pre-hud {
  width: 100%;
  margin-bottom: 10px;
  font-size: 14px;
  line-height: 1.45;
  color: #0f172a;
  text-align: center;
}

.match3__start-settings {
  width: 100%;
  margin-bottom: 12px;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 6px 10px;
  font-size: 13px;
  color: #334155;
}

.match3__hud {
  margin-bottom: 12px;
  font-size: 14px;
  line-height: 1.45;
  color: #0f172a;
}

.match3__hud--row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 8px 12px;
  width: 100%;
  box-sizing: border-box;
}

.match3__hud-sep {
  color: #94a3b8;
  user-select: none;
}

@media (max-width: 520px) {
  .match3__hud--row {
    justify-content: flex-start;
  }

  .match3__hud-sep {
    display: none;
  }

  .match3__start-settings {
    justify-content: flex-start;
  }
}

.match3__board {
  position: relative;
  width: 100%;
  max-width: 480px;
  margin: 0 auto;
}

.match3__canvas {
  display: block;
  width: 100%;
  height: auto;
  aspect-ratio: 1;
  border: 1px solid #2f4d73;
  border-radius: 8px;
  background: #081226;
  vertical-align: top;
}

.match3__overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20px;
  padding: 24px;
  box-sizing: border-box;
  border-radius: 8px;
  background: rgba(5, 12, 28, 0.88);
  backdrop-filter: blur(6px);
}

.match3__overlay--countdown {
  cursor: default;
}

.match3__countdown {
  font-size: clamp(72px, 18vw, 120px);
  font-weight: 800;
  line-height: 1;
  color: #e0f2fe;
  text-shadow:
    0 0 12px rgba(56, 189, 248, 0.95),
    0 0 28px rgba(99, 102, 241, 0.75),
    0 0 48px rgba(168, 85, 247, 0.45);
  animation: match3-pulse 0.9s ease-in-out infinite;
}

@keyframes match3-pulse {
  0%,
  100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.06);
    opacity: 0.92;
  }
}

.match3__overlay--ready .match3__play-btn {
  min-width: 160px;
  font-size: 16px;
  padding: 12px 24px;
}

.match3__overlay--results {
  text-align: center;
  color: #e2e8f0;
}

.match3__results-title {
  margin: 0 0 16px;
  font-size: 22px;
  font-weight: 700;
  color: #f8fafc;
  text-shadow: 0 0 14px rgba(56, 189, 248, 0.5);
}

.match3__results-list {
  margin: 0 0 20px;
  padding: 0;
  list-style: none;
  font-size: 16px;
  line-height: 1.6;
}

.match3__results-list li {
  margin: 0;
}

.match3__again-btn {
  min-width: 180px;
}

.landing--dark-neon .match3__pre-hud,
.landing--dark-neon .match3__hud {
  color: #e2e8f0;
}

.landing--dark-neon .match3__start-settings {
  color: #c7d2fe;
}

.landing--dark-neon .match3__hud-sep {
  color: #60a5fa;
}

.landing--dark-neon .match3-page__toast {
  color: #e2e8f0;
  background: rgba(15, 23, 42, 0.92);
  border: 1px solid rgba(56, 189, 248, 0.55);
  box-shadow: 0 0 16px rgba(56, 189, 248, 0.25);
}

.landing--dark-neon .match3-page__settings-btn {
  color: #7dd3fc;
  text-shadow: 0 0 10px rgba(56, 189, 248, 0.5);
}

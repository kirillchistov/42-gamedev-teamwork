/* тестовые стили для игрового поля */
.match3 {
  margin-top: 8px;
}

.match3__hud {
  margin-bottom: 10px;
  font-size: 14px;
}

.match3__canvas {
  display: block;
  width: 400px;
  max-width: 100%;
  border: 1px solid #2f4d73;
  border-radius: 8px;
  background: #081226;
}

.match3__settings-toggle {
  margin-top: 10px;
}

.match3__settings {
  margin-top: 10px;
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.match3__settings label {
  display: grid;
  gap: 4px;
}

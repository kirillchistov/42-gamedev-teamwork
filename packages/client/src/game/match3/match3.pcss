/* 
 * 6.1.2 Игровые настройки перед стартом:
 * Добавлены стили для настроек и селектов (match3__setting) 
*/

.match3 {
  width: 100%;
  max-width: 100%;
  margin-top: 8px;
}

.match3-page__toast-wrap {
  position: sticky;
  top: 8px;
  z-index: 20;
  margin-bottom: 12px;
  display: flex;
  justify-content: center;
}

.match3-page__toast {
  padding: 10px 14px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  color: #0f172a;
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid rgba(79, 70, 229, 0.25);
  box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
}

.match3-page__title {
  text-align: center;
}

.match3-page__note {
  text-align: center;
}

.match3-page__settings-btn {
  border: none;
  background: transparent;
  color: var(--color-accent-primary);
  text-decoration: underline;
  cursor: pointer;
  padding: 0;
  font: inherit;
}

.match3-page__settings-grid {
  margin: 12px auto 16px;
  max-width: 560px;
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(
    auto-fit,
    minmax(160px, 1fr)
  );
}

.match3-page__settings-label {
  display: grid;
  gap: 4px;
}

.match3__pre-hud {
  width: 100%;
  margin-bottom: 10px;
  font-size: 14px;
  line-height: 1.45;
  color: #0f172a;
  text-align: center;
}

.match3__start-settings {
  width: 100%;
  margin-bottom: 12px;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 6px 10px;
  font-size: 13px;
  color: #334155;
}

.match3__setting {
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.match3__setting select {
  border: 1px solid #94a3b8;
  border-radius: 6px;
  padding: 2px 6px;
  background: #fff;
  color: #0f172a;
  font-size: 13px;
}

.match3__hud {
  margin-bottom: 12px;
  font-size: 14px;
  line-height: 1.45;
  color: #0f172a;
}

.match3__hud--row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 8px 12px;
  width: 100%;
  box-sizing: border-box;
}

.match3__hud-sep {
  color: #94a3b8;
  user-select: none;
}

@media (max-width: 520px) {
  .match3__hud--row {
    justify-content: flex-start;
  }

  .match3__hud-sep {
    display: none;
  }

  .match3__start-settings {
    justify-content: flex-start;
  }
}

.match3__board {
  position: relative;
  width: 100%;
  max-width: 480px;
  margin: 0 auto;
}

.match3__canvas {
  display: block;
  width: 100%;
  height: auto;
  aspect-ratio: 1;
  border: 1px solid #2f4d73;
  border-radius: 8px;
  background: #081226;
  vertical-align: top;
}

.match3__overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20px;
  padding: 24px;
  box-sizing: border-box;
  border-radius: 8px;
  background: rgba(5, 12, 28, 0.88);
  backdrop-filter: blur(6px);
}

.match3__overlay--countdown {
  cursor: default;
}

.match3__countdown {
  font-size: clamp(72px, 18vw, 120px);
  font-weight: 800;
  line-height: 1;
  color: #e0f2fe;
  text-shadow:
    0 0 12px rgba(56, 189, 248, 0.95),
    0 0 28px rgba(99, 102, 241, 0.75),
    0 0 48px rgba(168, 85, 247, 0.45);
  animation: match3-pulse 0.9s ease-in-out infinite;
}

@keyframes match3-pulse {
  0%,
  100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.06);
    opacity: 0.92;
  }
}

.match3__overlay--ready .match3__play-btn {
  min-width: 160px;
  font-size: 16px;
  padding: 12px 24px;
}

.match3__overlay--results {
  text-align: center;
  color: #e2e8f0;
}

.match3__results-title {
  margin: 0 0 16px;
  font-size: 22px;
  font-weight: 700;
  color: #f8fafc;
  text-shadow: 0 0 14px rgba(56, 189, 248, 0.5);
}

.match3__results-list {
  margin: 0 0 20px;
  padding: 0;
  list-style: none;
  font-size: 16px;
  line-height: 1.6;
}

.match3__results-list li {
  margin: 0;
}

.match3__again-btn {
  min-width: 180px;
}

/* Рамка вокруг canvas (если используется класс game-board-frame) */
.game-board-frame {
  position: relative;
  padding: 8px;
  border-radius: 20px;
  background:
    radial-gradient(circle at 0 0, rgba(96, 165, 250, 0.45), transparent 60%),
    radial-gradient(circle at 100% 0, rgba(244, 114, 182, 0.45), transparent 60%),
    radial-gradient(circle at 50% 100%, rgba(56, 189, 248, 0.35), transparent 65%);
  box-shadow:
    0 0 0 1px rgba(148, 163, 184, 0.4),
    0 0 18px rgba(59, 130, 246, 0.7),
    0 0 36px rgba(129, 140, 248, 0.6);
  overflow: visible;
  animation: boardPulse 4.5s ease-in-out infinite alternate;
}

.game-board-canvas {
  display: block;
  max-width: 100%;
  height: auto;
  border-radius: 14px;
  box-shadow:
    0 8px 24px rgba(15, 23, 42, 0.6),
    0 0 0 1px rgba(148, 163, 184, 0.35);
  animation: boardJitter 1200ms ease-in-out infinite;
}

@keyframes boardPulse {
  0% {
    box-shadow:
      0 0 0 1px rgba(148, 163, 184, 0.35),
      0 0 14px rgba(59, 130, 246, 0.55),
      0 0 28px rgba(129, 140, 248, 0.45);
  }
  100% {
    box-shadow:
      0 0 0 1px rgba(191, 219, 254, 0.8),
      0 0 24px rgba(96, 165, 250, 0.95),
      0 0 45px rgba(244, 114, 182, 0.7);
  }
}

@keyframes boardJitter {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(1);
  }
  25% {
    transform: translate3d(-0.6px, 0.5px, 0) scale(1.002);
  }
  50% {
    transform: translate3d(0.7px, -0.4px, 0) scale(0.999);
  }
  75% {
    transform: translate3d(-0.4px, -0.6px, 0) scale(1.001);
  }
}

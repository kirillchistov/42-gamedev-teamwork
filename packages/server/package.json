{
  "name": "client",
  "version": "0.0.0",
  "scripts": {
    "dev": "yarn build:ssr-server && cross-env NODE_ENV=development EXTERNAL_SERVER_URL='http://localhost:3001' INTERNAL_SERVER_URL='http://localhost:3001' node server/index.js",
    "build:ssr-server": "tsc --project tsconfig.server.json",
    "build:client": "vite build",
    "build:ssr-client": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "build": "yarn build:ssr-server && yarn build:client && yarn build:ssr-client",
    "preview": "cross-env NODE_ENV=production node server/index.js",
    "start:ssr": "cross-env NODE_ENV=production node server/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "jest ./"
  },
  "dependencies": {
    "@gravity-ui/icons": "^2.18.0",
    "@gravity-ui/uikit": "^7.35.0",
    "@reduxjs/toolkit": "^1.9.5",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.0.2",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.2",
    "react-router-dom": "^6.16.0",
    "react-helmet": "^6.1.0",
    "redux": "^4.2.1",
    "serialize-javascript": "^6.0.1",
    "vite": "^4.4.9"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^13.3.0",
    "@types/jest": "^28.1.8",
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "@types/react-helmet": "^6.1.7",
    "@typescript-eslint/eslint-plugin": "^5.35.1",
    "@typescript-eslint/parser": "^5.35.1",
    "@vitejs/plugin-react": "^4.0.0",
    "vite-plugin-pwa": "^0.17.5",
    "eslint": "^8.23.0",
    "jest": "^28",
    "jest-environment-jsdom": "^29.0.1",
    "lefthook": "^1.3.9",
    "prettier": "^2.7.1",
    "eslint-config-prettier": "^8.5.0",
    "ts-jest": "^28.0.8",
    "typescript": "~6.0.2"
  },
  "license": "MIT"
}